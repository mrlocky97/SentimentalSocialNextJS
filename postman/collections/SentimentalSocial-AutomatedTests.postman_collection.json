        {
          "name": "Test 6: Get All User Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('📋 User jobs retrieved successfully', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "    pm.expect(jsonData.data.length).to.be.at.least(3); // We created 3 jobs",
                  "    ",
                  "    console.log('📊 Total user jobs:', jsonData.data.length);",
                  "    ",
                  "    // Analyze job statuses",
                  "    const statusCounts = {};",
                  "    jsonData.data.forEach((job, index) => {",
                  "        console.log(`Job ${index + 1}: ${job.jobId.substring(0, 8)}... - ${job.status} (${job.percentage}%) - ${job.tweetsCollected} tweets`);",
                  "        statusCounts[job.status] = (statusCounts[job.status] || 0) + 1;",
                  "    });",
                  "    ",
                  "    console.log('📊 Status Summary:', JSON.stringify(statusCounts, null, 2));",
                  "});"
                ],
                "type": "text/javascript"
