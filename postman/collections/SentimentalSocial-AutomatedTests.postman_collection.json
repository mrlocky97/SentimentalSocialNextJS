      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global pre-request setup",
          "console.log('🚀 Advanced Scraping Test -', pm.info.requestName);",
          "console.log('� Target URL:', pm.request.url.toString());",
          "",
          "// Ensure auth token is available",
          "if (!pm.environment.get('authToken')) {",
          "    console.warn('⚠️ No auth token found. Please run login first.');",
          "}",
          "",
          "// Set dynamic timestamp for unique data",
          "pm.environment.set('testTimestamp', Date.now());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test assertions",
          "pm.test('✅ Response received successfully', function () {",
          "    pm.response.to.have.status.oneOf([200, 201, 202]);",
          "});",
          "",
          "pm.test('📊 Response time acceptable', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(30000);",
          "});",
          "",
          "pm.test('📋 Valid JSON response', function () {",
          "    pm.response.to.be.json;",
          "    const jsonData = pm.response.json();",
          "    pm.expect(jsonData).to.have.property('success');",
          "});",
          "",
          "// Log response summary",
          "const jsonData = pm.response.json();",
          "console.log('📊 Status:', pm.response.code, pm.response.status);",
          "console.log('⚡ Time:', pm.response.responseTime + 'ms');",
          "console.log('✅ Success:', jsonData.success);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "🔐 Setup: Authentication",
      "description": "Authentication setup for automated tests",
      "item": [
        {
          "name": "Login and Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('🔐 Login successful', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('token');",
                  "    ",
                  "    // Save auth data",
                  "    pm.environment.set('authToken', jsonData.data.token);",
                  "    pm.environment.set('userId', jsonData.data.user.id);",
                  "    ",
                  "    console.log('🔑 Auth token saved');",
                  "    console.log('👤 User ID:', jsonData.data.user.id);",
                  "    console.log('📧 Email:', jsonData.data.user.email);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "login"]
            },
            "description": "Authenticate user and get JWT token for subsequent requests"
          }
        }
      ]
    },
