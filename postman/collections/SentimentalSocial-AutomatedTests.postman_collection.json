        {
          "name": "Test 7: Queue Statistics Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('📊 Queue statistics available', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('queueStats');",
                  "    ",
                  "    const stats = jsonData.data.queueStats;",
                  "    pm.expect(stats).to.have.property('waiting');",
                  "    pm.expect(stats).to.have.property('active');",
                  "    pm.expect(stats).to.have.property('completed');",
                  "    pm.expect(stats).to.have.property('failed');",
                  "    pm.expect(stats).to.have.property('total');",
                  "    ",
                  "    console.log('📊 Queue Statistics:');",
                  "    console.log('  ⏳ Waiting:', stats.waiting);",
                  "    console.log('  🔄 Active:', stats.active);",
                  "    console.log('  ✅ Completed:', stats.completed);",
                  "    console.log('  ❌ Failed:', stats.failed);",
                  "    console.log('  📈 Total:', stats.total);",
                  "    ",
                  "    if (jsonData.data.connectionStats) {",
                  "        console.log('🔌 WebSocket Connections:', jsonData.data.connectionStats.totalConnections);",
                  "        console.log('📡 Job Subscriptions:', jsonData.data.connectionStats.totalJobSubscriptions);",
                  "    }",
                  "    ",
                  "    if (jsonData.data.systemHealth) {",
                  "        console.log('🏥 System Health:');",
                  "        console.log('  ⏱️ Uptime:', Math.round(jsonData.data.systemHealth.uptime / 1000) + 's');",
                  "        console.log('  💾 Memory:', Math.round(jsonData.data.systemHealth.memoryUsage.heapUsed / 1024 / 1024) + 'MB');",
                  "    }",
                  "});"
