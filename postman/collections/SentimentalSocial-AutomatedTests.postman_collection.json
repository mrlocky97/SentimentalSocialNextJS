{
  "info": {
    "_postman_id": "automated-tests-advanced-scraping",
    "name": "SentimentalSocial - Automated Advanced Scraping Tests",
    "description": "Automated test suite for advanced scraping functionality with queue management, progress tracking, and WebSocket support. This collection tests the new large-scale scraping capabilities.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "3.0.0"
  },
  "auth": {
    "type": "bearer",
