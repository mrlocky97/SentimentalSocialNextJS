              "raw": "{{baseUrl}}/api/{{apiVersion}}/scraping/advanced/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "scraping", "advanced", "status"]
            },
            "description": "Check that the advanced scraping system is operational"
          }
