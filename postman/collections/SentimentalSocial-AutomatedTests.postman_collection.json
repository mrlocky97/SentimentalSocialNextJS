        {
          "name": "Test 2: Create Small Hashtag Job (100 tweets)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('🏷️ Small hashtag job created successfully', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('jobId');",
                  "    pm.expect(jsonData.data.targetCount).to.equal(100);",
                  "    pm.expect(jsonData.data.type).to.equal('hashtag');",
                  "    ",
                  "    // Save job ID for tracking",
                  "    pm.environment.set('smallHashtagJobId', jsonData.data.jobId);",
                  "    ",
                  "    console.log('✅ Small hashtag job created:', jsonData.data.jobId);",
                  "    console.log('🏷️ Hashtag:', jsonData.data.query);",
                  "    console.log('🎯 Target:', jsonData.data.targetCount, 'tweets');",
                  "    console.log('⚡ Priority:', jsonData.data.priority);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"hashtag\",\n  \"query\": \"#{{advancedHashtag}}\",\n  \"targetCount\": {{smallScrapeTarget}},\n  \"priority\": \"medium\",\n  \"options\": {\n    \"includeReplies\": false,\n    \"includeImages\": true,\n    \"language\": \"en\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/scraping/advanced/job",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "scraping", "advanced", "job"]
            },
            "description": "Create a small hashtag scraping job to test basic functionality"
          }
        },
        {
          "name": "Test 3: Track Small Job Progress",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('📊 Job progress tracking works', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    ",
                  "    if (jsonData.data) {",
                  "        pm.expect(jsonData.data).to.have.property('jobId');",
                  "        pm.expect(jsonData.data).to.have.property('status');",
                  "        pm.expect(jsonData.data).to.have.property('percentage');",
                  "        pm.expect(jsonData.data).to.have.property('currentBatch');",
                  "        pm.expect(jsonData.data).to.have.property('totalBatches');",
                  "        ",
                  "        console.log('📊 Progress:', jsonData.data.percentage + '%');",
                  "        console.log('📈 Status:', jsonData.data.status);",
                  "        console.log('🐦 Tweets:', jsonData.data.tweetsCollected);",
                  "        console.log('🔢 Batch:', jsonData.data.currentBatch + '/' + jsonData.data.totalBatches);",
                  "        ",
                  "        if (jsonData.data.throughput) {",
                  "            console.log('🚀 Throughput:', jsonData.data.throughput.toFixed(2) + ' tweets/sec');",
                  "        }",
                  "        ",
                  "        if (jsonData.data.estimatedTimeRemaining) {",
                  "            console.log('⏰ ETA:', Math.round(jsonData.data.estimatedTimeRemaining / 1000) + ' seconds');",
                  "        }",
                  "    } else {",
                  "        console.log('ℹ️ Job completed or not found');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/scraping/advanced/job/{{smallHashtagJobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "scraping", "advanced", "job", "{{smallHashtagJobId}}"]
            },
            "description": "Track progress of the small hashtag job"
          }
        },
