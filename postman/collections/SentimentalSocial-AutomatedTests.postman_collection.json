        {
          "name": "Test 1: System Status Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('🏥 System status is healthy', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('queueStats');",
                  "    pm.expect(jsonData.data).to.have.property('systemHealth');",
                  "    ",
                  "    console.log('📊 Queue Stats:', JSON.stringify(jsonData.data.queueStats, null, 2));",
                  "    console.log('🏥 System Health Status:', jsonData.data.systemHealth.status || 'healthy');",
                  "    ",
                  "    // Check if Redis is available",
                  "    const redisAvailable = jsonData.data.queueStats.redisAvailable !== false;",
                  "    console.log('🔴 Redis Available:', redisAvailable ? 'Yes' : 'No (using fallback)');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
