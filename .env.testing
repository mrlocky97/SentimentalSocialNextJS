# Configuración mínima para testing sin Redis
# Copia estas variables a tu .env file

# Redis Configuration (comment out if Redis not available)
# REDIS_URL=redis://localhost:6379

# Advanced Scraping Configuration
ENABLE_ADVANCED_SCRAPING=true
ENABLE_WEBSOCKET_PROGRESS=true
FRONTEND_URL=http://localhost:4200

# Queue Configuration (fallback to in-memory for testing)
QUEUE_MAX_CONCURRENT_JOBS=3
QUEUE_MAX_RETRIES=2
QUEUE_RETRY_DELAY=1000

# Testing mode (enables fallbacks)
NODE_ENV=development
