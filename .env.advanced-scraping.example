# Redis Configuration for Queue System
# Add these variables to your .env file

# Redis Connection
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue Configuration
QUEUE_MAX_CONCURRENT_JOBS=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=2000

# WebSocket Configuration
FRONTEND_URL=http://localhost:4200

# Advanced Scraping Configuration
MAX_TWEETS_PER_JOB=10000
DEFAULT_BATCH_SIZE=20
ADAPTIVE_DELAY_BASE=2000
ADAPTIVE_DELAY_MAX=120000

# Enable advanced scraping features
ENABLE_ADVANCED_SCRAPING=true
ENABLE_WEBSOCKET_PROGRESS=true
